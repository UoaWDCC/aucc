{
  "name": "@aucc/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server",
    "lint": "eslint --cache --ext \".js,.ts,.tsx\" src",
    "type-check": "tsc",
    "build": "rimraf dist && tsc --noEmit false && tsc-alias",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.12.0",
    "@trpc/server": "11.0.0-rc.819",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "superjson": "^2.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@aucc/eslint-config": "workspace:*",
    "@aucc/typescript-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
